{
  "name": "mini-coding-agent",
  "version": "0.1.0",
  "description": "A local conversational AI coding agent CLI.",
  "type": "module",
  "bin": {
    "mini-agent": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "mini-agent.config.example.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run build && npm test"
  },
  "keywords": [
    "agent",
    "coding-agent",
    "cli"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "commander": "^14.0.2",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
