{
  "version": 1,
  "llm": {
    "mode": "real",
    "baseUrl": "https://api.openai.com/v1",
    "apiKey": "replace-with-your-api-key",
    "model": "replace-with-your-model",
    "temperature": 0.2,
    "maxTokens": 4096,
    "timeoutMs": 60000
  },
  "rag": {
    "topK": 5,
    "minScore": 0.12,
    "maxContextChars": 6000
  },
  "multiAgent": {
    "mode": "auto",
    "maxConcurrency": 2,
    "maxBatchesPerRun": 1,
    "maxTasksPerRun": 3,
    "maxChildSteps": 4,
    "maxChildLlmCalls": 12,
    "maxChildToolCalls": 18,
    "maxResultChars": 6000
  },
  "mcp": {
    "servers": [
      {
        "name": "filesystem",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
        "enabled": false,
        "timeoutMs": 30000,
        "defaultPermission": "REVIEW",
        "toolPermissions": {
          "read_file": "SAFE"
        }
      }
    ]
  }
}
